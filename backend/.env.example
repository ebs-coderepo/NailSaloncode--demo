NODE_ENV=production
PORT=3001

# PostgreSQL — get this from Neon dashboard (use the "pooled" connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis — get this from Upstash dashboard (use the rediss:// URL)
REDIS_URL=rediss://default:password@host:port

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of your frontend URLs (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Frontend URL — used for Stripe payment redirect links
FRONTEND_URL=https://your-app.vercel.app

# Rate limiting
TOOL_RATE_LIMIT_WINDOW_MS=60000
TOOL_RATE_LIMIT_MAX=120
